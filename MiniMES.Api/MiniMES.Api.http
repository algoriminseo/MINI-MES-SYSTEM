@Host = http://localhost:5062
@itemId = 1
@processId = 1
@equipmentId = 1
@workerId = 1
@workOrderId = 1

### 00. API check
GET {{Host}}/openapi/v1.json
Accept: application/json

### 01. Create item
POST {{Host}}/api/items
Content-Type: application/json

{
  "itemCode": "ITEM-100",
  "itemName": "Bracket A",
  "specification": "100x50",
  "unit": "EA",
  "itemType": "Product",
  "safetyStock": 20
}

### 02. Create process
POST {{Host}}/api/processes
Content-Type: application/json

{
  "processCode": "CUT",
  "processName": "Cutting",
  "description": "Raw material cutting process",
  "sortOrder": 10,
  "isInspection": false
}

### 03. Create equipment
POST {{Host}}/api/equipments
Content-Type: application/json

{
  "equipmentCode": "CUT-01",
  "equipmentName": "Cutting Machine 01",
  "processId": {{processId}},
  "status": "Idle",
  "location": "Line A",
  "description": "Main cutting machine"
}

### 04. Create worker
POST {{Host}}/api/workers
Content-Type: application/json

{
  "workerCode": "WK-001",
  "workerName": "Kim Minsoo",
  "department": "Production",
  "role": "Operator",
  "shiftGroup": "A"
}

### 05. Check all master data
GET {{Host}}/api/items
Accept: application/json

### 06. Check processes
GET {{Host}}/api/processes
Accept: application/json

### 07. Check equipments
GET {{Host}}/api/equipments
Accept: application/json

### 08. Check workers
GET {{Host}}/api/workers
Accept: application/json

### 09. Create work order
POST {{Host}}/api/workorders
Content-Type: application/json

{
  "workOrderNo": "WO-TEST-001",
  "itemId": {{itemId}},
  "orderQuantity": 100,
  "plannedStartDate": "2026-05-12T09:00:00",
  "dueDate": "2026-05-15T18:00:00",
  "remark": "First work order test"
}

### 10. List work orders
GET {{Host}}/api/workorders
Accept: application/json

### 11. Get work order detail
GET {{Host}}/api/workorders/{{workOrderId}}
Accept: application/json

### 12. Release work order: Planned -> Released
PATCH {{Host}}/api/workorders/{{workOrderId}}/release

### 13. Start work order: Released -> InProgress
PATCH {{Host}}/api/workorders/{{workOrderId}}/start

### 14. Pause work order: InProgress -> Paused
PATCH {{Host}}/api/workorders/{{workOrderId}}/pause

### 15. Restart work order: Paused -> InProgress
PATCH {{Host}}/api/workorders/{{workOrderId}}/start

### 16. Complete work order: InProgress -> Completed
PATCH {{Host}}/api/workorders/{{workOrderId}}/complete

### 17. Check completed work order
GET {{Host}}/api/workorders/{{workOrderId}}
Accept: application/json

### 18. Filter work orders by status
GET {{Host}}/api/workorders?status=Completed
Accept: application/json

### 19. Equipment status board sample
PATCH {{Host}}/api/equipments/{{equipmentId}}/status
Content-Type: application/json

"Running"

### 20. Check running equipments
GET {{Host}}/api/equipments?status=Running
Accept: application/json

### 90. Error sample - duplicate item should return 409
POST {{Host}}/api/items
Content-Type: application/json

{
  "itemCode": "ITEM-100",
  "itemName": "Duplicate Bracket A",
  "specification": "100x50",
  "unit": "EA",
  "itemType": "Product",
  "safetyStock": 20
}

### 91. Error sample - invalid work order item should return 400
POST {{Host}}/api/workorders
Content-Type: application/json

{
  "workOrderNo": "WO-BAD-ITEM",
  "itemId": 999999,
  "orderQuantity": 100,
  "plannedStartDate": "2026-05-12T09:00:00",
  "dueDate": "2026-05-15T18:00:00",
  "remark": "Invalid item test"
}

### 92. Error sample - invalid status transition should return 400
PATCH {{Host}}/api/workorders/{{workOrderId}}/release
