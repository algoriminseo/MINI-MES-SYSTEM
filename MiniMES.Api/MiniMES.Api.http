@Host = http://localhost:5062
@itemId = 1
@processId = 1
@equipmentId = 1
@workerId = 1

### 00. API OpenAPI document
GET {{Host}}/openapi/v1.json
Accept: application/json

### 01-01. Items - create product
POST {{Host}}/api/items
Content-Type: application/json

{
  "itemCode": "ITEM-100",
  "itemName": "Bracket A",
  "specification": "100x50",
  "unit": "EA",
  "itemType": "Product",
  "safetyStock": 20
}

### 01-02. Items - create material
POST {{Host}}/api/items
Content-Type: application/json

{
  "itemCode": "MAT-100",
  "itemName": "Steel Plate",
  "specification": "SPCC 2T",
  "unit": "KG",
  "itemType": "Material",
  "safetyStock": 100
}

### 01-03. Items - list active
GET {{Host}}/api/items
Accept: application/json

### 01-04. Items - search by code or name
GET {{Host}}/api/items?search=ITEM
Accept: application/json

### 01-05. Items - get by id
GET {{Host}}/api/items/{{itemId}}
Accept: application/json

### 01-06. Items - duplicate code should return 409
POST {{Host}}/api/items
Content-Type: application/json

{
  "itemCode": "ITEM-100",
  "itemName": "Duplicate Bracket",
  "specification": "Duplicate",
  "unit": "EA",
  "itemType": "Product",
  "safetyStock": 0
}

### 01-07. Items - missing required values should return 400
POST {{Host}}/api/items
Content-Type: application/json

{
  "itemCode": "",
  "itemName": "",
  "specification": "Invalid",
  "unit": "EA",
  "itemType": "Product",
  "safetyStock": 0
}

### 01-08. Items - update
PUT {{Host}}/api/items/{{itemId}}
Content-Type: application/json

{
  "itemName": "Bracket A Updated",
  "specification": "100x50 Rev.B",
  "unit": "EA",
  "itemType": "Product",
  "safetyStock": 30,
  "isActive": true
}

### 01-09. Items - deactivate
DELETE {{Host}}/api/items/{{itemId}}

### 01-10. Items - list including inactive
GET {{Host}}/api/items?includeInactive=true
Accept: application/json

### 02-01. Processes - create cutting process
POST {{Host}}/api/processes
Content-Type: application/json

{
  "processCode": "CUT",
  "processName": "Cutting",
  "description": "Raw material cutting process",
  "sortOrder": 10,
  "isInspection": false
}

### 02-02. Processes - create inspection process
POST {{Host}}/api/processes
Content-Type: application/json

{
  "processCode": "INSP",
  "processName": "Inspection",
  "description": "Final quality inspection",
  "sortOrder": 90,
  "isInspection": true
}

### 02-03. Processes - list active
GET {{Host}}/api/processes
Accept: application/json

### 02-04. Processes - search by code or name
GET {{Host}}/api/processes?search=CUT
Accept: application/json

### 02-05. Processes - get by id
GET {{Host}}/api/processes/{{processId}}
Accept: application/json

### 02-06. Processes - duplicate code should return 409
POST {{Host}}/api/processes
Content-Type: application/json

{
  "processCode": "CUT",
  "processName": "Duplicate Cutting",
  "description": "Duplicate",
  "sortOrder": 20,
  "isInspection": false
}

### 02-07. Processes - missing required values should return 400
POST {{Host}}/api/processes
Content-Type: application/json

{
  "processCode": "",
  "processName": "",
  "description": "Invalid",
  "sortOrder": 30,
  "isInspection": false
}

### 02-08. Processes - update
PUT {{Host}}/api/processes/{{processId}}
Content-Type: application/json

{
  "processName": "Cutting Updated",
  "description": "Updated cutting process",
  "sortOrder": 10,
  "isInspection": false,
  "isActive": true
}

### 02-09. Processes - deactivate
DELETE {{Host}}/api/processes/{{processId}}

### 02-10. Processes - list including inactive
GET {{Host}}/api/processes?includeInactive=true
Accept: application/json

### 03-01. Equipments - create cutting equipment
POST {{Host}}/api/equipments
Content-Type: application/json

{
  "equipmentCode": "CUT-01",
  "equipmentName": "Cutting Machine 01",
  "processId": 1,
  "status": "Idle",
  "location": "Line A",
  "description": "Main cutting machine"
}

### 03-02. Equipments - create inspection equipment
POST {{Host}}/api/equipments
Content-Type: application/json

{
  "equipmentCode": "INSP-01",
  "equipmentName": "Inspection Station 01",
  "processId": 2,
  "status": "Idle",
  "location": "QA Room",
  "description": "Final inspection station"
}

### 03-03. Equipments - list active
GET {{Host}}/api/equipments
Accept: application/json

### 03-04. Equipments - filter by status
GET {{Host}}/api/equipments?status=Idle
Accept: application/json

### 03-05. Equipments - filter by process
GET {{Host}}/api/equipments?processId=1
Accept: application/json

### 03-06. Equipments - get by id
GET {{Host}}/api/equipments/{{equipmentId}}
Accept: application/json

### 03-07. Equipments - duplicate code should return 409
POST {{Host}}/api/equipments
Content-Type: application/json

{
  "equipmentCode": "CUT-01",
  "equipmentName": "Duplicate Cutting Machine",
  "processId": 1,
  "status": "Idle",
  "location": "Line A",
  "description": "Duplicate"
}

### 03-08. Equipments - invalid process should return 400
POST {{Host}}/api/equipments
Content-Type: application/json

{
  "equipmentCode": "BAD-01",
  "equipmentName": "Invalid Process Equipment",
  "processId": 999999,
  "status": "Idle",
  "location": "Line X",
  "description": "Invalid process id"
}

### 03-09. Equipments - invalid status should return 400
POST {{Host}}/api/equipments
Content-Type: application/json

{
  "equipmentCode": "BAD-02",
  "equipmentName": "Invalid Status Equipment",
  "processId": 1,
  "status": "Broken",
  "location": "Line X",
  "description": "Invalid status"
}

### 03-10. Equipments - update status only
PATCH {{Host}}/api/equipments/{{equipmentId}}/status
Content-Type: application/json

"Running"

### 03-11. Equipments - update
PUT {{Host}}/api/equipments/{{equipmentId}}
Content-Type: application/json

{
  "equipmentName": "Cutting Machine 01 Updated",
  "processId": 1,
  "status": "Maintenance",
  "location": "Line A",
  "description": "Updated cutting machine",
  "isActive": true
}

### 03-12. Equipments - deactivate
DELETE {{Host}}/api/equipments/{{equipmentId}}

### 03-13. Equipments - list including inactive
GET {{Host}}/api/equipments?includeInactive=true
Accept: application/json

### 04-01. Workers - create production worker
POST {{Host}}/api/workers
Content-Type: application/json

{
  "workerCode": "WK-001",
  "workerName": "Kim Minsoo",
  "department": "Production",
  "role": "Operator",
  "shiftGroup": "A"
}

### 04-02. Workers - create quality worker
POST {{Host}}/api/workers
Content-Type: application/json

{
  "workerCode": "WK-002",
  "workerName": "Lee Hana",
  "department": "Quality",
  "role": "Inspector",
  "shiftGroup": "B"
}

### 04-03. Workers - list active
GET {{Host}}/api/workers
Accept: application/json

### 04-04. Workers - search by code or name
GET {{Host}}/api/workers?search=WK
Accept: application/json

### 04-05. Workers - filter by department and shift
GET {{Host}}/api/workers?department=Production&shiftGroup=A
Accept: application/json

### 04-06. Workers - get by id
GET {{Host}}/api/workers/{{workerId}}
Accept: application/json

### 04-07. Workers - duplicate code should return 409
POST {{Host}}/api/workers
Content-Type: application/json

{
  "workerCode": "WK-001",
  "workerName": "Duplicate Worker",
  "department": "Production",
  "role": "Operator",
  "shiftGroup": "A"
}

### 04-08. Workers - missing required values should return 400
POST {{Host}}/api/workers
Content-Type: application/json

{
  "workerCode": "",
  "workerName": "",
  "department": "Production",
  "role": "Operator",
  "shiftGroup": "A"
}

### 04-09. Workers - update
PUT {{Host}}/api/workers/{{workerId}}
Content-Type: application/json

{
  "workerName": "Kim Minsoo Updated",
  "department": "Production",
  "role": "Line Leader",
  "shiftGroup": "A",
  "isActive": true
}

### 04-10. Workers - deactivate
DELETE {{Host}}/api/workers/{{workerId}}

### 04-11. Workers - list including inactive
GET {{Host}}/api/workers?includeInactive=true
Accept: application/json
